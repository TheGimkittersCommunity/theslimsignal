rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // 🔹 HELPERS (SAFE)
    // ============================

    function isLoggedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isAdmin() {
      return userDocExists() &&
        userData().role == "administrator";
    }

    function isMod() {
      return userDocExists() &&
        userData().role == "moderator";
    }

    function isStaff() {
      return isAdmin() || isMod();
    }

    function isSuspended() {
      return userDocExists() &&
        userData().isSuspended == true;
    }

    function isSilenced() {
      return userDocExists() &&
        userData().isSilenced == true;
    }

    function canPost() {
      return isLoggedIn() &&
        !isSuspended() &&
        !isSilenced();
    }

    // ============================
    // 🔹 CATEGORY HELPERS
    // ============================

    function categoryExists(catId) {
      return exists(/databases/$(database)/documents/categories/$(catId));
    }

    function categoryData(catId) {
      return categoryExists(catId)
        ? get(/databases/$(database)/documents/categories/$(catId)).data
        : null;
    }

    function categoryVisible(catId) {
      return isStaff() ||
        (categoryExists(catId) &&
         categoryData(catId).appearHidden == false);
    }

    // ============================
    // 🔹 TOPIC HELPERS
    // ============================

    function topicExists(topicId) {
      return exists(/databases/$(database)/documents/topics/$(topicId));
    }

    function topicData(topicId) {
      return topicExists(topicId)
        ? get(/databases/$(database)/documents/topics/$(topicId)).data
        : null;
    }

    function topicVisible(topicId) {
      return isStaff() ||
        (
          topicExists(topicId) &&
          topicData(topicId).appearDeleted == false &&
          categoryVisible(topicData(topicId).categoryId)
        );
    }

    // ============================
    // 🔹 USERS
    // ============================

    match /users/{userId} {
      allow read: if true;

      match /users/{userId} {
  allow create: if request.auth != null
    && request.auth.uid == userId
    && request.resource.data.role == "member";
}

      allow update: if isLoggedIn() &&
        request.auth.uid == userId &&
        !isSuspended() &&
        !request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasAny(["role", "isSuspended", "isSilenced"]);

      allow delete: if (isLoggedIn() &&
        request.auth.uid == userId) || isStaff();
    }

    // ============================
    // 🔹 CATEGORIES
    // ============================

    match /categories/{categoryId} {

      // Read: public unless hidden
      allow read: if resource.data.appearHidden == false
                  || isStaff();

      // Only staff can manage categories
      allow create, update, delete: if isStaff();
    }

    // ============================
    // 🔹 TOPICS
    // ============================

    match /topics/{topicId} {

      // Read topic if visible
      allow read: if resource.data.appearDeleted == false
                  && categoryVisible(resource.data.categoryId)
                  || isStaff();

      // Create topic
      allow create: if canPost()
        && categoryVisible(request.resource.data.categoryId);

      // Update/Delete
      allow update, delete: if canPost() &&
        (request.auth.uid == resource.data.authorId || isStaff());
    }

    // ============================
    // 🔹 POSTS (REPLIES)
    // ============================

    match /posts/{postId} {

      allow read: if resource.data.appearDeleted == false
                  || isStaff();

      allow create: if canPost() &&
        (
          topicVisible(request.resource.data.topicId)

          || !topicExists(request.resource.data.topicId)
        );

      allow update, delete: if canPost() &&
        (request.auth.uid == resource.data.authorId || isStaff());
    }
  }
}